---
import { render } from "astro:content";
import BaseLayout from "@/layouts/base-layout.astro";
import PostNav from "@/components/post-nav.astro";
import NewsletterForm from "@/components/newsletter-form.astro";
import GiscusComments from "@/components/giscus-comments.astro";
import { RevealFx } from "@/components/effects/reveal-fx";
import { getPublishedPosts, type Post } from "@/lib/posts";
import { slugify } from "@/lib/slugify";
import { formatDate, isoDate } from "@/lib/format-date";
import { author } from "@/config";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  /* posts sort pubDate giảm dần → prev (cũ hơn) = i+1, next (mới hơn) = i−1 */
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null,
      next: posts[i - 1] ?? null,
    },
  }));
}

interface Props {
  post: Post;
  prev: Post | null;
  next: Post | null;
}

const { post, prev, next } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const minutes = remarkPluginFrontmatter.minutesRead;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  image={post.data.cover?.src}
>
  <!-- Reading progress — vanilla JS (user chốt 2026-07-16), chạy cả khi reduced-motion (§7.3) -->
  <div class="fx-progress" aria-hidden="true"></div>

  <article data-pagefind-body>
    <header class="post-header">
      <h1 class="post-title fx-title">{post.data.title}</h1>
      <p class="byline fx-title-sub">
        <span>{author}</span>
        <span class="dot"><time datetime={isoDate(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time></span>
        <span class="dot">{minutes} phút đọc</span>
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <ul class="tag-list" aria-label="Chủ đề của bài viết">
        {post.data.tags.map((tag) => (
          <li><a class="tag" href={`/chu-de/${slugify(tag)}/`}>{tag}</a></li>
        ))}
      </ul>

      <RevealFx client:visible>
        <NewsletterForm
          heading="Thấy bài viết hữu ích?"
          text="Đăng ký để nhận bài mới qua email — mỗi tháng một thư, không spam."
        />
      </RevealFx>

      <!-- KHÔNG bọc trong island: RevealFx đổi cây React sau hydration sẽ
           remount slot → iframe Giscus bị phá + script re-inject không chạy
           (code review 2026-07-16, finding High #1) -->
      <GiscusComments />
    </footer>
  </article>

  <RevealFx client:visible>
    <PostNav prev={prev} next={next} />
  </RevealFx>

  <script>
    /* Reading progress — rAF throttle, port nguyên từ wireframe post.html.
       KHÔNG gate theo html.fx: phản hồi trực tiếp thao tác cuộn nên vẫn
       chạy khi prefers-reduced-motion (design-guidelines §7.3). */
    const bar = document.querySelector<HTMLElement>(".fx-progress");
    if (bar) {
      let ticking = false;
      const update = () => {
        const d = document.documentElement;
        const max = d.scrollHeight - d.clientHeight;
        bar.style.transform = `scaleX(${max > 0 ? Math.min(d.scrollTop / max, 1) : 0})`;
        ticking = false;
      };
      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        },
        { passive: true },
      );
      update();
    }
  </script>
</BaseLayout>
