---
import BaseLayout from "@/layouts/base-layout.astro";
import { PostListFx } from "@/components/effects/post-list-fx";
import { getPublishedPosts, type Post } from "@/lib/posts";
import { slugify } from "@/lib/slugify";
import { toPostCardData } from "@/lib/post-card-data";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const byTag = new Map<string, { tag: string; posts: Post[] }>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      const entry = byTag.get(slug) ?? { tag, posts: [] };
      entry.posts.push(post);
      byTag.set(slug, entry);
    }
  }
  return [...byTag.entries()].map(([slug, { tag, posts }]) => ({
    params: { tag: slug },
    props: { tag, posts },
  }));
}

interface Props {
  tag: string;
  posts: Post[];
}

const { tag, posts } = Astro.props;
const cards = await toPostCardData(posts);
---

<BaseLayout
  title={`Chủ đề: ${tag}`}
  description={`Các bài viết thuộc chủ đề "${tag}" trên blog.`}
>
  <header class="page-header">
    <h1 class="fx-title">Chủ đề: {tag}</h1>
    <p class="filter-note fx-title-sub">
      {posts.length} bài viết · <a href="/chu-de/">Xem tất cả chủ đề</a>
    </p>
  </header>

  <h2 class="sr-only">Danh sách bài viết</h2>
  <PostListFx client:visible posts={cards} />
</BaseLayout>
